# Required: Postgres connection string used by API, db:init, seed, and tests.
# Example format:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
DATABASE_URL=

# Optional: API port (defaults to 3001)
# PORT=3001

# Optional: enables OpenAI answer phrasing when set.
# Leave unset for deterministic template responses.
# OPENAI_API_KEY=your_openai_api_key

# Optional: OpenAI model override (defaults to gpt-4o-mini in code).
# OPENAI_MODEL=gpt-4o-mini
