# Copy to .env and fill in values. Never commit .env.
# Neon / Postgres connection string (include sslmode if your host requires TLS).
DATABASE_URL=postgresql://USER:PASSWORD@HOSTNAME/DATABASE?sslmode=require

# npm run db:init runs `psql -f src/db/schema.sql` (needs `psql` on your PATH).

# Optional (see src/config/env.ts)
# PORT=3001
# NODE_ENV=development
