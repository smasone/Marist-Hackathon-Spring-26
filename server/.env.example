# Postgres connection (Neon or local). Required for the server and for `npm test`.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Optional — defaults to 3001
# PORT=3001

# ---------------------------------------------------------
# AI Provider (optional)
# When OPENAI_API_KEY is set, supported /api/parking/ask intents may rephrase
# the grounded template using OpenAI; if unset or on API errors, templates are used.
# ---------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini